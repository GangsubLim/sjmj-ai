# macmini 배포용 env. ~/.sjmj-ai/backend.env 로 복사 후 값 채우고 chmod 600.
# launchd는 .zshrc/.bashrc를 로드하지 않으므로 UV_BIN은 절대경로 필수.
# UV_BIN: macmini(submini) 실측값 = Homebrew 경로(2026-06-24 SP0 배포 검증).
# 다른 호스트면 로그인 셸 `command -v uv`로 재확인 후 절대경로 기입.
UV_BIN=/opt/homebrew/bin/uv
SJMJ_HOST=127.0.0.1
SJMJ_PORT=8400
SJMJ_STATIC_DIR=/Users/submini/sjmj-ai/apps/invoice-ocr/frontend/dist
LOG_LEVEL=info

# 런타임 + 백업 공통 DB 접속(backup-db.sh와 단일 출처 공유).
# Phase 1D 운영 실측 = root / 무비번 / 127.0.0.1 / DB_NAME=sjmj.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sjmj
DB_USER=root
DB_PASS=
