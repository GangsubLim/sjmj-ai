# Phase 1C 프론트 → FastAPI(1B modern 구조화 envelope) 연결 설정.
# 실제 .env / .env.production 은 비추적(로컬). 이 파일을 복사해 사용한다.
#   cp .env.example .env           # dev: vite proxy(/api→:8400)
#   cp .env.example .env.production # build: 동일출처(backend가 dist+/api 서빙)
VITE_API_URL=/api
VITE_API_MODE=modern
VITE_USE_MOCK=false
